{
  "name": "portalhost-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "mobile",
    "desktop-agent"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "desktop": "npm run start --workspace=desktop-agent",
    "start": "npm run mobile",
    "android": "npm run android --workspace=mobile",
    "ios": "npm run ios --workspace=mobile",
    "web": "npm run web --workspace=mobile",
    "lint": "npm run lint --workspace=mobile"
  },
  "dependencies": {
    "expo": "~56.0.12",
    "react": "19.2.3",
    "react-native": "0.85.3"
  }
}
