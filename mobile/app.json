{
  "expo": {
    "name": "PortalHost",
    "slug": "PortalHost",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/portal_host_icon.png",
    "scheme": "portalhost",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1a1a2e",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false
      }
    },
    "android": {
      "package": "com.portalhost.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/portal_host_icon.png",
        "backgroundImage": "./assets/images/portal_host_icon.png",
        "monochromeImage": "./assets/images/portal_host_icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/portal_host_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1a2e",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
